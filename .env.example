# DEPLOY CHECKLIST (run once before first docker compose up):
# 1. Copy this file to .env and fill in all values: cp .env.example .env && chmod 0600 .env
# 2. Run Alembic migrations against Neon: DATABASE_URL=<your-url> alembic upgrade head
# 3. Start services: docker compose -f docker-compose.prod.yml up -d
# 4. Restore procedure: see docs/ops/restore-runbook.md (OPS-02)

# ─── Required ────────────────────────────────────────────────────────────────

ENVIRONMENT=production
LOG_LEVEL=INFO

# Neon managed Postgres — get from Neon dashboard (Project → Connection Details)
# Must include ?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.aws.neon.tech/dbname?ssl=require

# Redis — use Docker service name 'redis' (not localhost) when running inside compose
# REDIS_PASSWORD must match the value set in docker-compose.prod.yml
REDIS_PASSWORD=changeme
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Anthropic API key — used by classify_items worker (Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI key — used by embed_items worker for vector embeddings
VOYAGE_API_KEY=pa-...

# Hard daily LLM spend limit in USD — enforced before each Anthropic API call
DAILY_SPEND_LIMIT=10.0

# LLM spend alert threshold in USD — Slack alert fires when spend crosses this value
LLM_DAILY_ALERT_THRESHOLD=7.0

# Model identifiers — defaults match training; override only if switching models
LLM_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=voyage-3.5-lite
EMBEDDING_DIM=1024

# ─── Optional ─────────────────────────────────────────────────────────────────

# GitHub personal access token — higher rate limits (5000/hr vs 60/hr unauthenticated)
# GITHUB_TOKEN=ghp_...

# Slack incoming webhook URL — required for alerts and dead man's switch notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Mailgun webhook signing key — required in production for newsletter email ingestion
# Get from Mailgun Dashboard → Webhooks → Signing Key
# MAILGUN_WEBHOOK_SIGNING_KEY=
